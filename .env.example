# --- OpenAI-compatible vision endpoint (used by scripts/extract.py and admin "re-extract") ---
OPENAI_ENDPOINT="https://your-gateway.example/v1"
OPENAI_MODEL="your-vision-capable-model"
OPENAI_APIKEY="sk-..."

# --- Web app ---
# Long random string; sessions are invalidated if this changes.
SESSION_SECRET="change-me-to-a-long-random-string"
# Allow self-service registration (true/false).
REGISTRATION_OPEN=true
# Set true when served over HTTPS (incl. Cloudflare Tunnel) so the session cookie is marked Secure.
COOKIE_SECURE=false
# Behind a reverse proxy / tunnel: read the real client IP from CF-Connecting-IP /
# X-Real-IP / X-Forwarded-For for rate limiting. Set false only if exposed directly (no proxy).
TRUST_PROXY_HEADERS=true
# Optional: auto-promote this existing username to admin on startup.
# ADMIN_USERNAME=
