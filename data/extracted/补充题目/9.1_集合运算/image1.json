  "stem": "下列集合运算中错误的是：",
  "options": [
    {"label": "A", "text": "$A \\cup B = B \\cup A$"},
    {"label": "B", "text": "$A \\cap B = B \\cap A$"},
    {"label": "C", "text": "$A \\cup (B \\cap C) = (A \\cup B) \\cap (A \\cup C)$"},
    {"label": "D", "text": "$A \\cup (B \\cap C) = (A \\cap B) \\cup (A \\cap C)$"}
